PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./beacon.db

# Optional: real email delivery via SMTP (e.g. Gmail, SendGrid, Mailgun). If
# unset, OTP codes and invite emails are logged to the console instead (fine
# for local dev, not for production).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: link included in "invite a friend" emails.
APP_DOWNLOAD_URL=https://beaconchat.app/download
