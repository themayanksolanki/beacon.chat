PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./beacon.db

# Optional: real email delivery via Brevo (https://brevo.com). If unset,
# OTP codes and invite emails are logged to the console instead (fine for
# local dev, not for production). BREVO_FROM needs a verified sender/domain
# in Brevo before it can send to arbitrary recipients.
BREVO_API_KEY=
BREVO_FROM=no-reply@beaconchat.app
BREVO_FROM_NAME=Beacon

# Optional: link included in "invite a friend" emails.
APP_DOWNLOAD_URL=https://beaconchat.app/download

# Optional: MongoDB connection string for user profile data (name, avatar).
# If unset, profile reads/writes are disabled and lookups just omit
# name/avatarUrl (auth/identity data stays in the SQLite db regardless).
MONGODB_URI=

# DEV ONLY: set to "true" to expose POST /auth/dev-login, which issues a
# session for any email/publicKey with no OTP check at all — a full
# authentication bypass. Leave unset everywhere except local/throwaway dev
# environments; never set this in production.
SKIP_OTP=


# need to use ORM and Chats handling for different account in same device