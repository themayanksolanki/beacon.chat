{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "expo": "~57.0.4",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-contacts": "~57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-libsodium": "^1.7.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-webrtc": "^124.0.7",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "libsodium-wrappers": "^0.8.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "expo-android:dev": "eas build --platform android --profile development",
    "expo-android:preview": "eas build --platform android --profile preview",
    "expo-android:prod": "eas build --platform android --profile production",
    "expo-ios:dev": "eas build --platform ios --profile development",
    "expo-ios:preview": "eas build --platform ios --profile preview",
    "expo-ios:prod": "eas build --platform ios --profile production"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-incall-manager",
          "react-native-libsodium",
          "react-native-webrtc"
        ]
      }
    }
  }
}
