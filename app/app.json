{
  "expo": {
    "name": "Beacon",
    "slug": "beacon-chat",
    "scheme": "beacon-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.beaconchat.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Beacon can use Face ID to protect access to your encryption keys.",
        "NSCameraUsageDescription": "Beacon needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "Beacon needs microphone access for voice and video calls.",
        "ITSAppUsesNonExemptEncryption": true,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.beaconchat.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "./plugins/withDisableScriptSandboxing.js",
      [
        "expo-image-picker",
        {
          "photosPermission": "Beacon needs access to your photos so you can set a profile picture."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Beacon needs access to your contacts to show which of them are already on Beacon."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Beacon needs microphone access for voice and video calls."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f01534f3-0332-42cc-b62b-933b49b40ffb"
      }
    },
    "owner": "mayanksolanki"
  }
}
